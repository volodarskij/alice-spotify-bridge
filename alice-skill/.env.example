# Spotify application credentials — https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# OAuth redirect URI registered in the Spotify dashboard.
# Must be HTTPS and reachable from your browser during the one-time auth.
SPOTIFY_REDIRECT_URI=https://your-domain.example.com/callback

# Groq API key (optional) — https://console.groq.com
# Enables LLM parsing of voice commands; regex fallback is used without it.
GROQ_API_KEY=

# TLS certificate for the Alice webhook (HTTPS is mandatory for Yandex Dialogs)
SSL_KEY_FILE=/root/ssl_key.pem
SSL_CERT_FILE=/root/ssl_cert.pem

# SOCKS proxy for Spotify/Groq API calls (optional; remove if you have direct access)
SOCKS_PROXY=socks5h://127.0.0.1:1070

# Log verbosity: debug | info | warn | error
LOG_LEVEL=info
