#!/bin/sh /etc/rc.common
# Alice Skill webhook for voice-controlled Spotify
# OpenWrt procd service template.
#
# Fill in before use:
#   SPOTIFY_CLIENT_ID / SPOTIFY_CLIENT_SECRET — from https://developer.spotify.com/dashboard
#   GROQ_API_KEY — optional, from https://console.groq.com (LLM command parsing;
#                  without it the skill falls back to regex parsing)
START=99
USE_PROCD=1

start_service() {
    # Wait for the SOCKS proxy to be ready.
    # Remove this block if you don't route Spotify API calls through SOCKS.
    local retries=0
    while ! curl -s -x socks5h://127.0.0.1:1070 --max-time 3 https://accounts.spotify.com > /dev/null 2>&1; do
        retries=$((retries + 1))
        [ $retries -ge 20 ] && { logger -t alice_spotify "SOCKS proxy not ready after 60s, starting anyway"; break; }
        sleep 3
    done

    procd_open_instance
    procd_set_param command /usr/bin/node /root/alice_spotify.js
    procd_set_param env HOME=/root \
        LOG_LEVEL=info \
        SPOTIFY_CLIENT_ID=YOUR_SPOTIFY_CLIENT_ID \
        SPOTIFY_CLIENT_SECRET=YOUR_SPOTIFY_CLIENT_SECRET \
        GROQ_API_KEY=YOUR_GROQ_API_KEY \
        SSL_KEY_FILE=/root/ssl_key.pem \
        SSL_CERT_FILE=/root/ssl_cert.pem
    procd_set_param respawn 60 10 0
    procd_set_param stdout 1
    procd_set_param stderr 1
    procd_close_instance
}
